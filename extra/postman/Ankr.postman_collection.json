						"method": "POST",
						"body": { "mode": "raw", "raw": "{\n \"publicInvestmentsTotal\": 200000, \"profileId\": \"{{PROFILE_ID}}\"\n}", "options": { "raw": { "language": "json" } } },
						"url": { "raw": "{{BASE_URL}}/assets" }
